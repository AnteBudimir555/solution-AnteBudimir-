# Copy to .env before `docker compose up`:  cp .env.example .env
# docker compose auto-loads .env from this directory. The real .env is gitignored.
#
# These are throwaway DEMO values. Generate a real JWT_SECRET (>= 32 bytes for HS256)
# for any real deployment, e.g.:
#   openssl rand -base64 48

DB_USERNAME=middleware
DB_PASSWORD=middleware
JWT_SECRET=docker-demo-insecure-jwt-secret-change-me-0123456789
